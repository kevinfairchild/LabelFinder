<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- Camera preview fills the screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Frozen frame -->
    <ImageView
        android:id="@+id/frozenFrameView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="matrix"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay for bounding boxes -->
    <com.labelfinder.BarcodeOverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView" />

    <!-- Found lock-on action buttons -->
    <LinearLayout
        android:id="@+id/freezeActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/keepLookingButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Keep Looking"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:layout_marginEnd="12dp"
            app:cornerRadius="28dp"
            app:backgroundTint="#546E7A" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/markFoundButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Mark as Found"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:cornerRadius="28dp"
            app:backgroundTint="#4CAF50" />
    </LinearLayout>

    <!-- Scan input action buttons -->
    <LinearLayout
        android:id="@+id/scanInputActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanInputCancelButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Cancel"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            app:cornerRadius="28dp"
            app:backgroundTint="#546E7A" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanInputSearchButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Search"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:visibility="gone"
            android:layout_marginEnd="8dp"
            app:cornerRadius="28dp"
            app:backgroundTint="#1565C0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanInputAddToListButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Add to List"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:visibility="gone"
            app:cornerRadius="28dp"
            app:backgroundTint="#4CAF50" />
    </LinearLayout>

    <!-- Search bar at the top -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#E6FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

            <!-- Multi search toggle -->
            <ImageButton
                android:id="@+id/batchToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_add"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle multi search"
                android:tooltipText="Toggle multi search"
                android:alpha="0.6" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/searchInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search barcode"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:boxBackgroundColor="@android:color/transparent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/searchInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Scan input button -->
            <ImageButton
                android:id="@+id/scanInputButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_camera"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Scan barcode as input"
                android:tooltipText="Scan barcode as input" />

            <!-- Torch toggle -->
            <ImageButton
                android:id="@+id/torchButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_flashlight_off"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle flashlight"
                android:tooltipText="Toggle flashlight" />

            <ImageButton
                android:id="@+id/historyButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Search history"
                android:tooltipText="Search history" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_manage"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:tooltipText="Settings" />

            <ImageButton
                android:id="@+id/clearButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear search"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Zoom level indicator -->
    <TextView
        android:id="@+id/zoomText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.0x"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:background="@drawable/status_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Multi search panel -->
    <LinearLayout
        android:id="@+id/batchPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/statusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/batchCountText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Multi: empty"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/clearAllButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear All"
                android:textColor="#EF5350"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/batchItemsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Status bar at the bottom -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:padding="12dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/status_background"
        android:text="Enter a barcode value to search"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
